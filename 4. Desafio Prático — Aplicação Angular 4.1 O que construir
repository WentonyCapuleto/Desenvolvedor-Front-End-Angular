import { Injectable } from '@angular/core';
import { delay, Observable, of, throwError } from 'rxjs';
import { Usuario } from './usuario.model';

@Injectable({ providedIn: 'root' })
export class UsuarioService {

  private usuarios: Usuario[] = [
    { id: 1, nome: 'João', email: 'joao@email.com', cpf: '123', telefone: '9999', tipo_telefone: 'celular' },
    { id: 2, nome: 'Maria', email: 'maria@email.com', cpf: '456', telefone: '8888', tipo_telefone: 'fixo' }
  ];

  listar(): Observable<Usuario[]> {
    return of(this.usuarios).pipe(delay(800));
  }

  salvar(usuario: Usuario): Observable<Usuario> {
    if (!usuario.id) {
      usuario.id = Date.now();
      this.usuarios.push(usuario);
    } else {
      this.usuarios = this.usuarios.map(u => u.id === usuario.id ? usuario : u);
    }

    return of(usuario).pipe(delay(500));
  }
}

Componente de listagem (Signals + debounce)
import {
  ChangeDetectionStrategy,
  Component,
  signal,
  computed
} from '@angular/core';

import { FormControl, ReactiveFormsModule } from '@angular/forms';
import {
  debounceTime,
  distinctUntilChanged,
  startWith
} from 'rxjs/operators';

import { UsuarioService } from './usuario.service';
import { Usuario } from './usuario.model';

@Component({
  selector: 'app-usuarios',
  standalone: true,
  imports: [ReactiveFormsModule],
  templateUrl: './usuarios.component.html',
  changeDetection: ChangeDetectionStrategy.OnPush
})
export class UsuariosComponent {

  readonly filtro = new FormControl<string>('', { nonNullable: true });

  readonly usuarios = signal<Usuario[]>([]);
  readonly loading = signal<boolean>(false);
  readonly erro = signal<string | null>(null);

  readonly modal_aberto = signal<boolean>(false);
  readonly usuario_edicao = signal<Usuario | null>(null);

  readonly usuarios_filtrados = computed(() => {
    const termo = this.filtro.value?.toLowerCase() ?? '';
    return this.usuarios().filter(u => u.nome.toLowerCase().includes(termo));
  });

  constructor(private readonly service: UsuarioService) {
    this.carregar();

    this.filtro.valueChanges.pipe(
      startWith(''),
      debounceTime(300),
      distinctUntilChanged()
    ).subscribe();
  }

  carregar(): void {
    this.loading.set(true);

    this.service.listar().subscribe({
      next: (data) => {
        this.usuarios.set(data);
        this.loading.set(false);
      },
      error: () => {
        this.erro.set('Erro ao carregar usuários');
        this.loading.set(false);
      }
    });
  }

  abrir_modal(usuario?: Usuario): void {
    this.usuario_edicao.set(usuario ?? null);
    this.modal_aberto.set(true);
  }

  fechar_modal(): void {
    this.modal_aberto.set(false);
  }

  salvar(usuario: Usuario): void {
    this.service.salvar(usuario).subscribe(() => {
      this.carregar();
      this.fechar_modal();
    });
  }
}

Template (UI moderna)
<div class="container">

  <div class="header">
    <input [formControl]="filtro" placeholder="Buscar por nome..." />

    <button class="btn-add" (click)="abrir_modal()">
      + Novo
    </button>
  </div>

  <div *ngIf="loading()">Carregando...</div>
  <div *ngIf="erro()">{{ erro() }}</div>

  <div class="grid">
    <div class="card" *ngFor="let user of usuarios_filtrados()">
      <h3>{{ user.nome }}</h3>
      <p>{{ user.email }}</p>

      <button (click)="abrir_modal(user)">Editar</button>
    </div>
  </div>

  <app-usuario-modal
    *ngIf="modal_aberto()"
    [usuario]="usuario_edicao()"
    (fechar)="fechar_modal()"
    (salvar)="salvar($event)">
  </app-usuario-modal>

</div>

Modal (Form reativo completo)
import {
  Component,
  EventEmitter,
  Input,
  Output,
  OnInit
} from '@angular/core';

import { FormBuilder, Validators, ReactiveFormsModule } from '@angular/forms';
import { Usuario } from './usuario.model';

@Component({
  selector: 'app-usuario-modal',
  standalone: true,
  imports: [ReactiveFormsModule],
  templateUrl: './usuario-modal.component.html'
})
export class UsuarioModalComponent implements OnInit {

  @Input() usuario: Usuario | null = null;

  @Output() salvar = new EventEmitter<Usuario>();
  @Output() fechar = new EventEmitter<void>();

  form = this.fb.group({
    id: [0],
    nome: ['', Validators.required],
    email: ['', [Validators.required, Validators.email]],
    cpf: ['', Validators.required],
    telefone: ['', Validators.required],
    tipo_telefone: ['celular', Validators.required]
  });

  constructor(private fb: FormBuilder) {}

  ngOnInit(): void {
    if (this.usuario) {
      this.form.patchValue(this.usuario);
    }
  }

  submit(): void {
    if (this.form.valid) {
      this.salvar.emit(this.form.getRawValue() as Usuario);
    }
  }
}

Template Modal
<div class="modal">
  <form [formGroup]="form" (ngSubmit)="submit()">

    <h2>{{ form.value.id ? 'Editar' : 'Novo' }} usuário</h2>

    <input formControlName="nome" placeholder="Nome" />
    <div *ngIf="form.controls.nome.invalid && form.controls.nome.touched">
      Nome obrigatório
    </div>

    <input formControlName="email" placeholder="Email" />
    <div *ngIf="form.controls.email.invalid && form.controls.email.touched">
      Email inválido
    </div>

    <input formControlName="cpf" placeholder="CPF" />
    <input formControlName="telefone" placeholder="Telefone" />

    <select formControlName="tipo_telefone">
      <option value="celular">Celular</option>
      <option value="fixo">Fixo</option>
    </select>

    <button type="submit" [disabled]="form.invalid">
      Salvar
    </button>

    <button type="button" (click)="fechar.emit()">
      Cancelar
    </button>

  </form>
</div>

