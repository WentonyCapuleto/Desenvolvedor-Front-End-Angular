import { bootstrapApplication } from '@angular/platform-browser';
import { provideHttpClient } from '@angular/common/http';
import { UsuariosComponent } from './app/usuarios.component';

bootstrapApplication(UsuariosComponent, {
  providers: [provideHttpClient()]
}).catch(console.error);

export interface Usuario {
  id: number;
  nome: string;
  email: string;
  cpf: string;
  telefone: string;
  tipo_telefone: 'celular' | 'fixo';
}

import { Injectable } from '@angular/core';
import { Observable, of } from 'rxjs';
import { delay } from 'rxjs/operators';
import { Usuario } from './usuario.model';

@Injectable({ providedIn: 'root' })
export class UsuarioService {

  private usuarios: Usuario[] = [
    { id: 1, nome: 'João', email: 'joao@email.com', cpf: '123', telefone: '9999', tipo_telefone: 'celular' },
    { id: 2, nome: 'Maria', email: 'maria@email.com', cpf: '456', telefone: '8888', tipo_telefone: 'fixo' }
  ];

  listar(): Observable<Usuario[]> {
    return of(this.usuarios).pipe(delay(500));
  }

  salvar(usuario: Usuario): Observable<Usuario> {
    if (!usuario.id) {
      usuario.id = Date.now();
      this.usuarios.push(usuario);
    } else {
      this.usuarios = this.usuarios.map(u =>
        u.id === usuario.id ? usuario : u
      );
    }

    return of(usuario).pipe(delay(300));
  }
}

import { Component, Input, Output, EventEmitter } from '@angular/core';
import { CommonModule } from '@angular/common';
import { ReactiveFormsModule, FormBuilder, Validators } from '@angular/forms';
import { Usuario } from './usuario.model';

@Component({
  selector: 'app-usuario-modal',
  standalone: true,
  imports: [CommonModule, ReactiveFormsModule],
  template: `
  <div class="modal">
    <form [formGroup]="form" (ngSubmit)="submit()">

      <h2>{{ form.value.id ? 'Editar' : 'Novo' }} usuário</h2>

      <input formControlName="nome" placeholder="Nome" />
      <small *ngIf="form.controls.nome.touched && form.controls.nome.invalid">
        Nome obrigatório
      </small>

      <input formControlName="email" placeholder="Email" />
      <small *ngIf="form.controls.email.touched && form.controls.email.invalid">
        Email inválido
      </small>

      <input formControlName="cpf" placeholder="CPF" />
      <input formControlName="telefone" placeholder="Telefone" />

      <select formControlName="tipo_telefone">
        <option value="celular">Celular</option>
        <option value="fixo">Fixo</option>
      </select>

      <button type="submit" [disabled]="form.invalid">Salvar</button>
      <button type="button" (click)="fechar.emit()">Cancelar</button>

    </form>
  </div>
  `
})
export class UsuarioModalComponent {

  @Input() usuario: Usuario | null = null;
  @Output() salvar = new EventEmitter<Usuario>();
  @Output() fechar = new EventEmitter<void>();

  form = this.fb.group({
    id: [0],
    nome: ['', Validators.required],
    email: ['', [Validators.required, Validators.email]],
    cpf: ['', Validators.required],
    telefone: ['', Validators.required],
    tipo_telefone: ['celular', Validators.required]
  });

  constructor(private fb: FormBuilder) {}

  ngOnInit(): void {
    if (this.usuario) {
      this.form.patchValue(this.usuario);
    }
  }

  submit(): void {
    if (this.form.valid) {
      this.salvar.emit(this.form.getRawValue() as Usuario);
    }
  }
}

import { Component, ChangeDetectionStrategy } from '@angular/core';
import { CommonModule } from '@angular/common';
import { ReactiveFormsModule, FormControl } from '@angular/forms';

import { UsuarioService } from './usuario.service';
import { Usuario } from './usuario.model';
import { UsuarioModalComponent } from './usuario-modal.component';

import {
  debounceTime,
  distinctUntilChanged,
  switchMap,
  catchError,
  map,
  startWith
} from 'rxjs/operators';

import { Observable, of } from 'rxjs';

interface ViewModel {
  loading: boolean;
  usuarios: Usuario[];
  erro: string | null;
}

@Component({
  selector: 'app-usuarios',
  standalone: true,
  imports: [CommonModule, ReactiveFormsModule, UsuarioModalComponent],
  changeDetection: ChangeDetectionStrategy.OnPush,
  template: `
  <div class="container">

    <div class="header">
      <input [formControl]="filtro" placeholder="Buscar usuário..." />
      <button (click)="abrir_modal()">+ Novo</button>
    </div>

    <ng-container *ngIf="vm$ | async as vm">

      <div *ngIf="vm.loading">Carregando...</div>
      <div *ngIf="vm.erro">{{ vm.erro }}</div>

      <div class="grid">
        <div class="card" *ngFor="let user of vm.usuarios">
          <h3>{{ user.nome }}</h3>
          <p>{{ user.email }}</p>
          <button (click)="abrir_modal(user)">Editar</button>
        </div>
      </div>

    </ng-container>

    <app-usuario-modal
      *ngIf="modal_aberto"
      [usuario]="usuario_edicao"
      (salvar)="salvar($event)"
      (fechar)="fechar_modal()">
    </app-usuario-modal>

  </div>
  `
})
export class UsuariosComponent {

  filtro = new FormControl<string>('', { nonNullable: true });

  modal_aberto = false;
  usuario_edicao: Usuario | null = null;

  vm$: Observable<ViewModel> = this.filtro.valueChanges.pipe(
    startWith(''),
    debounceTime(300),
    distinctUntilChanged(),

    switchMap((termo) =>
      this.service.listar().pipe(

        map(usuarios => ({
          loading: false,
          usuarios: usuarios.filter(u =>
            u.nome.toLowerCase().includes(termo.toLowerCase())
          ),
          erro: null
        })),

        catchError(() =>
          of({
            loading: false,
            usuarios: [],
            erro: 'Erro ao carregar usuários'
          })
        ),

        startWith({
          loading: true,
          usuarios: [],
          erro: null
        })
      )
    )
  );

  constructor(private service: UsuarioService) {}

  abrir_modal(usuario?: Usuario): void {
    this.usuario_edicao = usuario ?? null;
    this.modal_aberto = true;
  }

  fechar_modal(): void {
    this.modal_aberto = false;
  }

  salvar(usuario: Usuario): void {
    this.service.salvar(usuario).subscribe(() => {
      this.modal_aberto = false;
    });
  }
}

.container { max-width: 900px; margin: auto; padding: 20px; }
.header { display: flex; justify-content: space-between; margin-bottom: 20px; }
.grid { display: grid; gap: 10px; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }
.card { padding: 10px; background: #f5f5f5; border-radius: 8px; }
.modal {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.5);
  display: flex; align-items: center; justify-content: center;
}
